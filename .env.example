# =============================================================================
# NexusTrade Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Placeholder values allow unit tests to run without real credentials.
# =============================================================================

# --- LLM API Keys ---
# Required for cloud LLM mode. Get keys from respective providers.
ANTHROPIC_API_KEY=sk-ant-placeholder
OPENAI_API_KEY=sk-placeholder

# --- Broker API Keys (US Equities) ---
# Alpaca paper trading keys (free signup at https://alpaca.markets)
ALPACA_API_KEY=placeholder
ALPACA_SECRET=placeholder

# --- OpenAlgo (Indian Brokers) ---
# Local OpenAlgo instance for Zerodha, Dhan, etc.
OPENALGO_API_KEY=placeholder
OPENALGO_HOST=http://localhost:5000

# --- Ollama (Local LLM) ---
# Local Ollama instance for offline/private LLM inference
OLLAMA_BASE_URL=http://localhost:11434

# --- Redis ---
# Redis instance for event bus, caching, and pub/sub
REDIS_URL=redis://localhost:6379

# --- TradingView ---
# Passphrase for authenticating TradingView webhook alerts
TV_PASSPHRASE=nexustrade_dev_secret

# --- Notifications (Optional) ---
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Discord webhook URL for trade notifications
DISCORD_WEBHOOK_URL=
